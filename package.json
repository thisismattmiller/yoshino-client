{
  "name": "yoshino-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "cd client && npx vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
